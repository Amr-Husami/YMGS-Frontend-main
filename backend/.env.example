# ----------------------------------------------------------------------------
# YMGS Backend environment variables
# Copy this file to `.env` and fill in real values:  cp .env.example .env
# ----------------------------------------------------------------------------

# Port the Express server listens on
PORT=4000

# Comma-separated list of origins allowed by CORS (your React dev + prod URLs)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000,https://www.ymgspharmacy.com

# --- Supabase ---------------------------------------------------------------
# Project URL (Settings > API > Project URL)
SUPABASE_URL=https://vglfucrvqpdrodprkkor.supabase.co

# Anon / publishable key — safe for browsers, restricted by Row Level Security.
SUPABASE_ANON_KEY=sb_publishable_EpcOnpNzb_7PRAz-HJBhYg_UGvOOwZT

# Service-role / secret key (Settings > API > service_role).
# REQUIRED for the backend so it can read/write past Row Level Security.
# NEVER expose this in the frontend or commit it. Falls back to anon key if unset.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# --- Auth -------------------------------------------------------------------
# Secret used to sign JWTs. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d
